generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  googleId   String?  @unique
  nickname   String
  birthMonth Int
  birthDate  Int
  memo       String
  createdAt  DateTime @default(now())
}
